<Window x:Class="WpfStandaloneUpdateApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="My App" Height="420" Width="560"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid x:Name="MainContent" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Installed version: " FontWeight="Bold"/>
                <TextBlock x:Name="CurrentVersionText" Text="—"/>
            </StackPanel>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                <TextBlock Text="Status: " FontWeight="Bold"/>
                <TextBlock x:Name="StatusText" Text="Idle" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="CheckUpdateButton" Content="Check for Updates" Padding="10,4" Click="CheckUpdateButton_Click"/>
                <ProgressBar x:Name="BackgroundUpdateProgress" Width="150" Height="16" Margin="10,0,0,0"
                             IsIndeterminate="True" Visibility="Collapsed"/>
            </StackPanel>

            <StackPanel Grid.Row="3" Margin="0,0,0,10">
                <TextBlock Text="App features (example - halted during a major update):"
                           FontWeight="Bold" Margin="0,10,0,4" TextWrapping="Wrap"/>
                <Button x:Name="DoWorkButton" Content="Do Some Work" Padding="10,4"
                        HorizontalAlignment="Left" Click="DoWorkButton_Click"/>
            </StackPanel>
        </Grid>

        <Grid x:Name="MajorUpdateOverlay" Background="#CC000000" Visibility="Collapsed">
            <Border Background="White" CornerRadius="8" Padding="24" Width="360"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="A required update is available" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="MajorUpdateDetailsText" Margin="0,8,0,8" TextWrapping="Wrap"/>
                    <ProgressBar x:Name="MajorUpdateProgress" Height="18" Minimum="0" Maximum="100"
                                 Margin="0,0,0,10" Visibility="Collapsed"/>
                    <TextBlock x:Name="MajorUpdateStatusText" Margin="0,0,0,10" TextWrapping="Wrap"/>
                    <Button x:Name="MajorUpdateButton" Content="Update Now" Padding="10,6"
                            HorizontalAlignment="Right" Click="MajorUpdateButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
